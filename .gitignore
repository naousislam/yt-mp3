# Bun cache
.bun

# Local curl / debugging artifacts
stream-out.bin
server.log
launcher.log

# Packaged desktop binaries — produced by `bun run package:*`,
# published as GitHub release artifacts. Each one is 80–110 MB and
# tied to the OS/arch of the runner that built it; we don't want
# them in the source tree.
/dist/

# yt-dlp binary — downloaded fresh by scripts/install-yt-dlp.mjs on
# every `bun install` / `npm install`. Don't commit it: 18 MB+ per
# platform, and we want each user to get the latest stable build
# rather than whatever was current when this repo was last pushed.
/bin/

# Debug player-script dumps that ytdl-core writes to the project root
# whenever it fails to parse YouTube's signature cipher. Harmless but
# noisy in `git status`.
*-player-script.js

# Other lockfiles (we use bun, so bun.lockb should be committed)
package-lock.json
yarn.lock
pnpm-lock.yaml
